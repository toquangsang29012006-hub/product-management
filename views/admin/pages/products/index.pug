extends ../../layouts/default.pug 

block main 
    h1 Trang danh sách sản phẩm

    table.table.table-hover.table-sm
        thead 
            tr 
                th STT
                th Hình ảnh
                th Tiêu đề 
                th Giá
                th Trạng thái
                th Hàng động 

        tbody 
            tr 
                td 1
                td 
                    img(
                        src=""
                        alt="Sản phẩm 1"
                        width="100px"
                        height="auto"
                    )
                td Sản phẩm 1
                td 100$
                td 
                    a(href="#" class="badge bg-success") Hoạt động 
                td 
                    button(class="btn btn-warning btn-sm") Sửa
                    button(class="btn btn-danger btn-sm ms-2") Xóa 
            tr 
                td 2
                td 
                    img(
                        src=""
                        alt="Sản phẩm 2"
                        width="150px"
                        height="auto"
                    )
                td Sản phẩm 2
                td 150$
                td 
                    a(href="#" class="badge bg-danger") Dừng hoạt động 
                td 
                    button(class="btn btn-warning btn-sm") Sửa
                    button(class="btn btn-danger btn-sm ms-2") Xóa 
